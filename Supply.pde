class Supply{
  float x, y;
  float speed;
  float SupplyWidth, SupplyHeight;
  
  Supply(float x, float y, float speed, float SupplyWidth, float SupplyHeight){
  this.x = x;
  this.y = y;
  this.speed = speed;
  this.SupplyWidth = SupplyWidth;
  this.SupplyHeight = SupplyHeight;
  }
}
