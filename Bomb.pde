class Bomb{
  float x, y;
  float speed;
  float bulletWidth, bulletHeight;
  
  Bomb(float x, float y, float speed, float bulletWidth, float bulletHeight){
  this.x = x;
  this.y = y;
  this.speed = speed;
  this.bulletWidth = bulletWidth;
  this.bulletHeight = bulletHeight;
  
  }


}
